# Backend URL used by the Vite dev server and the production build.
# In development this is overridden by the Vite proxy, but it is still
# required as a fallback so api.js has a sensible default.
# For production, set this to your Render service URL before running
# `npm run build`, e.g. https://my-product-api.onrender.com
VITE_API_URL=http://localhost:8000
